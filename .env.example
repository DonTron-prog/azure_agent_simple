# Copy to .env and fill in from the Azure OpenAI resource.
OPENAI_ENDPOINT=
CHAT_DEPLOYMENT=gpt-4o

# Where the SQLite warehouse + per-run logs live. Relative to the project root.
# On an Azure ML compute instance keep the project under ~/cloudfiles/... so
# this survives stop/start.
WAREHOUSE_DB=data/warehouse.db
RUNS_DIR=data/runs

# Reference date for "current_month", "prior_month", etc.
# Defaults to the max InvoiceDate in the warehouse if unset.
REFERENCE_DATE=
